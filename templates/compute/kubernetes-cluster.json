{
  "kind": "kubernetes_cluster",
  "flavor": "eks_standard",
  "version": "1.0",
  "metadata": {"name": "kubernetes-cluster"},
  "disabled": true,
  "spec": {
    "cluster_version": "1.32",
    "cluster_endpoint_public_access": true,
    "cluster_endpoint_private_access": true,
    "customer_managed_kms": true,
    "cluster_addons": {
      "coredns": {"enabled": true, "version": "latest"},
      "kube_proxy": {"enabled": true, "version": "latest"},
      "vpc_cni": {"enabled": true, "version": "latest"},
      "ebs_csi": {"enabled": true, "version": "latest"},
      "metrics_server": {"enabled": true, "version": "latest"}
    }
  },
  "inputs": {
    "cloud_account": {
      "resource_type": "cloud_account",
      "resource_name": "cloud"
    },
    "network_details": {
      "resource_type": "network",
      "resource_name": "network"
    }
  }
}
