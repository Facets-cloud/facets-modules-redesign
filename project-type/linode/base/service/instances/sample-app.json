{
  "kind": "service",
  "flavor": "k8s",
  "version": "1.0",
  "disabled": false,
  "spec": {
    "type": "application",
    "enable_host_anti_affinity": false,
    "restart_policy": "Always",
    "pod_distribution_enabled": false,
    "pod_distribution": {},
    "release": {
      "strategy": {
        "type": "RollingUpdate"
      },
      "image": "nginx:1.27"
    },
    "runtime": {
      "args": [],
      "command": [],
      "autoscaling": {
        "scaling_on": "CPU",
        "min": 1,
        "max": 1,
        "cpu_threshold": "50"
      },
      "ports": {},
      "size": {
        "cpu": "300m",
        "memory": "1Gi",
        "cpu_limit": "1000m",
        "memory_limit": "5Gi"
      },
      "health_checks": {
        "readiness_check_type": "None",
        "liveness_check_type": "None"
      }
    },
    "env": {
      "LOG_LEVEL": "INFO"
    },
    "init_containers": {},
    "sidecars": {}
  },
  "inputs": {
    "kubernetes_details": {
      "resource_name": "cluster",
      "resource_type": "kubernetes_cluster",
      "output_name": "attributes"
    },
    "kubernetes_node_pool_details": {
      "resource_name": "workers",
      "resource_type": "kubernetes_node_pool"
    }
  }
}